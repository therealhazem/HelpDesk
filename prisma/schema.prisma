// HelpDesk Lite — Prisma Schema
// Architecture artifact (pre-implementation)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum RoleName {
  EMPLOYEE
  AGENT
  MANAGER
  ADMIN
}

enum TicketStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  BLOCKED
  WAITING_FOR_REQUESTER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReadinessState {
  READY
  PARTIAL
  BLOCKED
  NOT_READY
}

enum CommentType {
  PUBLIC
  INTERNAL
}

enum TicketHistoryAction {
  CREATED
  ASSIGNED
  REASSIGNED
  STATUS_CHANGED
  PRIORITY_CHANGED
  BLOCKED
  UNBLOCKED
  COMMENT_ADDED
  RESOLUTION_ADDED
  CLOSED
  READINESS_CHANGED
  UPDATED
}

enum NotificationType {
  ASSIGNED
  REASSIGNED
  BLOCKED
  COMMENT
  STATUS_CHANGED
}

enum ReviewStatus {
  ACCEPTED
  NEEDS_REVISION
  REJECTED
  ROLLED_BACK
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Role {
  id        String   @id @default(uuid())
  name      RoleName @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("roles")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  roleId       String    @map("role_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  role Role @relation(fields: [roleId], references: [id])

  requestedTickets     Ticket[]             @relation("TicketRequester")
  assignedTickets      Ticket[]             @relation("TicketAssignee")
  assignments          Assignment[]         @relation("AssignmentAssignee")
  assignmentsMade      Assignment[]         @relation("AssignmentAssignedBy")
  comments             Comment[]
  ticketHistoryEntries TicketHistory[]
  notifications        Notification[]
  verificationReviews  VerificationRecord[]
  auditLogs            AuditLog[]

  @@index([roleId])
  @@index([deletedAt])
  @@index([email])
  @@map("users")
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tickets Ticket[]

  @@index([isActive])
  @@index([deletedAt])
  @@map("categories")
}

model Ticket {
  id                 String           @id @default(uuid())
  ticketNumber       String           @unique @map("ticket_number")
  title              String
  description        String           @db.Text
  categoryId         String           @map("category_id")
  priority           TicketPriority   @default(MEDIUM)
  status             TicketStatus     @default(NEW)
  readiness          ReadinessState   @default(NOT_READY)
  requesterId        String           @map("requester_id")
  assigneeId         String?          @map("assignee_id")
  dueDate            DateTime?        @map("due_date")
  isBlocked          Boolean          @default(false) @map("is_blocked")
  blockerReason      String?          @map("blocker_reason") @db.Text
  statusBeforeBlock  TicketStatus?    @map("status_before_block")
  resolutionSummary  String?          @map("resolution_summary") @db.Text
  resolvedAt         DateTime?        @map("resolved_at")
  closedAt           DateTime?        @map("closed_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  deletedAt          DateTime?        @map("deleted_at")

  category      Category        @relation(fields: [categoryId], references: [id])
  requester     User            @relation("TicketRequester", fields: [requesterId], references: [id])
  assignee      User?           @relation("TicketAssignee", fields: [assigneeId], references: [id])
  assignments   Assignment[]
  comments      Comment[]
  history       TicketHistory[]
  notifications Notification[]

  @@index([status])
  @@index([priority])
  @@index([requesterId])
  @@index([assigneeId])
  @@index([categoryId])
  @@index([isBlocked])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([status, assigneeId])
  @@index([dueDate])
  @@map("tickets")
}

model Assignment {
  id           String   @id @default(uuid())
  ticketId     String   @map("ticket_id")
  assigneeId   String   @map("assignee_id")
  assignedById String   @map("assigned_by_id")
  note         String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  ticket     Ticket @relation(fields: [ticketId], references: [id])
  assignee   User   @relation("AssignmentAssignee", fields: [assigneeId], references: [id])
  assignedBy User   @relation("AssignmentAssignedBy", fields: [assignedById], references: [id])

  @@index([ticketId, createdAt])
  @@index([assigneeId])
  @@map("assignments")
}

model Comment {
  id        String      @id @default(uuid())
  ticketId  String      @map("ticket_id")
  authorId  String      @map("author_id")
  type      CommentType @default(PUBLIC)
  content   String      @db.Text
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  deletedAt DateTime?   @map("deleted_at")

  ticket Ticket @relation(fields: [ticketId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([ticketId])
  @@index([authorId])
  @@index([deletedAt])
  @@map("comments")
}

model TicketHistory {
  id        String              @id @default(uuid())
  ticketId  String              @map("ticket_id")
  actorId   String              @map("actor_id")
  action    TicketHistoryAction
  metadata  Json?
  createdAt DateTime            @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id])
  actor  User   @relation(fields: [actorId], references: [id])

  @@index([ticketId, createdAt])
  @@index([actorId])
  @@map("ticket_history")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  ticketId  String?          @map("ticket_id")
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model VerificationRecord {
  id                 String             @id @default(uuid())
  featureName        String             @map("feature_name")
  reviewStatus       ReviewStatus       @map("review_status")
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  reviewerId         String             @map("reviewer_id")
  verificationNotes  String?            @map("verification_notes") @db.Text
  evidence           Json               @default("[]")
  verificationDate   DateTime?          @map("verification_date")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  deletedAt          DateTime?          @map("deleted_at")

  reviewer User @relation(fields: [reviewerId], references: [id])

  @@index([reviewStatus])
  @@index([verificationStatus])
  @@index([reviewerId])
  @@index([deletedAt])
  @@map("verification_records")
}

model AuditLog {
  id         String      @id @default(uuid())
  actorId    String      @map("actor_id")
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  action     AuditAction
  metadata   Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  actor User @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}
